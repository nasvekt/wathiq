---
// Contact — Request a Demo
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Wathiq Compliance Gateway">
  <nav class="fixed top-0 left-0 right-0 z-50 bg-tech-black/95 backdrop-blur-sm border-b border-white/5">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center"><span class="text-primary font-bold text-sm">و</span></div>
        <span class="text-white font-semibold text-lg">Wathiq</span>
      </a>
    </div>
  </nav>

  <section class="bg-tech-black pt-32 pb-24 min-h-screen">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-16">
        <h1 class="text-5xl md:text-6xl text-white font-onest font-normal mb-4">Request a Demo</h1>
        <p class="text-xl text-charcoal">See Wathiq in action. We'll run your payroll through all 10 compliance engines.</p>
      </div>

      <div class="bg-surface border border-white/5 rounded-2xl p-8 md:p-12">
        <form action="https://formsubmit.co/your@email.com" method="POST" class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm text-white-grey mb-2">Full Name</label>
              <input type="text" name="name" required class="w-full bg-tech-black border border-white/10 rounded-lg px-4 py-3 text-white focus:border-primary/50 focus:outline-none transition" placeholder="Your name" />
            </div>
            <div>
              <label class="block text-sm text-white-grey mb-2">Email</label>
              <input type="email" name="email" required class="w-full bg-tech-black border border-white/10 rounded-lg px-4 py-3 text-white focus:border-primary/50 focus:outline-none transition" placeholder="your@company.com" />
            </div>
          </div>
          <div>
            <label class="block text-sm text-white-grey mb-2">Company</label>
            <input type="text" name="company" required class="w-full bg-tech-black border border-white/10 rounded-lg px-4 py-3 text-white focus:border-primary/50 focus:outline-none transition" placeholder="Company name" />
          </div>
          <div>
            <label class="block text-sm text-white-grey mb-2">Employee Count</label>
            <select name="size" class="w-full bg-tech-black border border-white/10 rounded-lg px-4 py-3 text-white focus:border-primary/50 focus:outline-none transition">
              <option value="1-49">10–49 employees</option>
              <option value="50-499">50–499 employees</option>
              <option value="500+">500+ employees</option>
              <option value="eor">EOR / HRIS platform</option>
            </select>
          </div>
          <div>
            <label class="block text-sm text-white-grey mb-2">Message</label>
            <textarea name="message" rows="4" class="w-full bg-tech-black border border-white/10 rounded-lg px-4 py-3 text-white focus:border-primary/50 focus:outline-none transition" placeholder="Tell us about your compliance needs..."></textarea>
          </div>
          <button type="submit" class="w-full bg-primary hover:bg-primary-dark text-tech-black font-semibold text-base px-8 py-4 rounded-lg transition">
            Submit Request
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>